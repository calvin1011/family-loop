# Copy to .env and fill in your values. Never commit .env.

# Supabase (Settings → API: Project URL + anon public key)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Sign-In — OAuth 2.0 "Web application" client from Google Cloud Console.
# Must match Authentication → Providers → Google in Supabase (Client IDs + Client Secret there).
# The client SECRET is only pasted in Supabase; it is not used in this file.
# Also register Android/iOS OAuth clients in Google Cloud (SHA-1 for Android) and add those
# client IDs in Supabase Google provider (comma-separated) per Supabase Google auth docs.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional reference IDs for your Google Cloud OAuth clients (Supabase dashboard lists them too).
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Phone OTP: the app only calls signInWithOtp. SMS is sent by Supabase using the Send SMS Hook
# (../supabase/functions/send-sms-hook). Set MOBILE_TEXT_ALERTS_API_KEY and SEND_SMS_HOOK_SECRET
# as Edge Function secrets (not in this file). Enable Phone in Auth and the hook in the dashboard.
# See https://supabase.com/docs/guides/auth/auth-hooks/send-sms-hook
